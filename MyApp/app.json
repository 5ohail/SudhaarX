{
  "expo": {
    "name": "SudhaarX",
    "slug": "SudhaarX",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/SudhaarX.jpeg",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.SudhaarX.app"
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "package": "com.SudhaarX.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/SudhaarX.jpeg",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "" 
        }
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow SudhaarX to access location."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fd7ddc31-875b-49a7-beb5-c8a29eff63e4"
      }
    }
  }
}
